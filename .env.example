# AI Service
GROQ_API_KEY=your_groq_api_key_here

# Google OAuth (for Google Sign-In)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# App URLs
MY_BACKEND_DOMAIN=http://localhost:5000
MY_FRONTEND_URL=http://localhost:5173

# Google Custom Search API (for music discovery)
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key
GOOGLE_CSE_ID=your_custom_search_engine_id

# PostgreSQL Database
PG_SQL_URL=jdbc:postgresql://localhost:5432/song_db
PG_SQL_USERNAME=postgres
PG_SQL_PASSWORD=your_db_password
